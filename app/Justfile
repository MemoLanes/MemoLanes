set windows-powershell := true

# Show list of available commands
default:
  @echo "📋 Available commands:"
  @just --list

# ---- Utils ----

[group: 'utils']
[working-directory: 'journey_kernel']
journey-kernel-build:
    @echo "🛠️  Building Journey Kernel"
    @yarn build
    @echo "✅ Journey Kernel build completed"

[group: 'utils']
copy-webview-assets:
    @echo "📁 Copying webview assets to Flutter"
    @mkdir -p assets/map_webview
    @rm -rf assets/map_webview/*
    @cp -r journey_kernel/dist/* assets/map_webview/
    @echo "✅ Webview assets copied"

[group: 'utils']
frb-generate:
    @echo "🔗 Generating FRB code"
    @flutter_rust_bridge_codegen generate
    @echo "✅ FRB code generation completed"

[group: 'utils']
[working-directory: 'rust']
rust-fmt:
    @echo "🛠️  Formatting code"
    @cargo fmt --all
    @echo "✅ Code formatting completed"

[group: 'utils']
[working-directory: 'journey_kernel']
journey-kernel-fmt:
    @echo "🛠️  Formatting code"
    @yarn format
    @cargo fmt --all
    @echo "✅ Code formatting completed"

[group: 'utils']
[working-directory: 'rust/geo_data_format']
geo-data-format-fmt:
    @echo "🛠️  Formatting code"
    @cargo fmt --all
    @echo "✅ Code formatting completed"

[group: 'utils']
[working-directory: '../tools/geo_rasterizer']
geo-rasterizer-fmt:
    @echo "🛠️  Formatting code"
    @cargo fmt --all
    @echo "✅ Code formatting completed"

[group: 'utils']
flutter-fmt:
    @echo "🛠️  Formatting code"
    @dart format .
    @echo "✅ Code formatting completed"

[group: 'utils']
flutter-check:
    @echo "🔍 Analyzing Flutter code"
    @flutter analyze
    @echo "✅ Flutter code analysis completed"

[group: 'utils']
flutter-test:
    @echo "🧪 Running Flutter tests"
    @flutter test
    @echo "✅ Flutter tests completed"

[group: 'utils']
[working-directory: 'rust']
rust-check:
    @echo "🔍 Checking Rust code"
    @cargo check
    @cargo fmt --all -- --check
    @cargo clippy -- -D warnings
    @echo "✅ Rust code check completed"

[group: 'utils']
[working-directory: 'journey_kernel']
journey-kernel-check:
    @echo "🔍 Checking Journey Kernel code"
    @yarn check-format
    @yarn check-types
    @cargo check
    @cargo fmt --all -- --check
    @cargo clippy -- -D warnings
    @echo "✅ Journey Kernal code check completed"

[group: 'utils']
[working-directory: 'rust/geo_data_format']
geo-data-format-check:
    @echo "🔍 Checking geo_data_format code"
    @cargo check --all-targets
    @cargo fmt --all -- --check
    @cargo clippy --all-targets -- -D warnings
    @echo "✅ geo_data_format code check completed"

[group: 'utils']
[working-directory: '../tools/geo_rasterizer']
geo-rasterizer-check:
    @echo "🔍 Checking geo_rasterizer code"
    @cargo check --all-targets
    @cargo fmt --all -- --check
    @cargo clippy --all-targets -- -D warnings
    @echo "✅ geo_rasterizer code check completed"

[group: 'utils']
[working-directory: 'rust']
rust-test:
    @echo "🧪 Running Rust tests"
    @cargo test -- --nocapture
    @echo "✅ Rust tests completed"

[group: 'utils']
[working-directory: 'journey_kernel']
journey-kernel-test:
    @echo "🧪 Running Journey Kernel tests"
    @cargo test -- --nocapture
    @echo "✅ Journey Kernel tests completed"

[group: 'utils']
[working-directory: 'rust/geo_data_format']
geo-data-format-test:
    @echo "🧪 Running geo_data_format tests"
    @cargo test -- --nocapture
    @echo "✅ geo_data_format tests completed"

[group: 'utils']
[working-directory: '../tools/geo_rasterizer']
geo-rasterizer-test:
    @echo "🧪 Running geo_rasterizer tests"
    @cargo test -- --nocapture
    @echo "✅ geo_rasterizer tests completed"

[group: 'utils']
[unix]
get-frb-version:
    @awk '/flutter_rust_bridge:/ { print $2 }' pubspec.yaml

# Regenerate the frozen id registry (append-only union over Pov::ALL); a prerequisite of rasterize-geo so the CI guardrail diff is meaningful
[group: 'dev']
registry-gen:
    cargo run --manifest-path ../tools/geo_rasterizer/Cargo.toml --release --bin registry_gen
    @echo "✅ geo_entity_registry.toml regenerated (union over Pov::ALL)"

[group: 'dev']
rasterize-geo: registry-gen
    cargo run --manifest-path ../tools/geo_rasterizer/Cargo.toml --release --bin geo_rasterizer -- \
      --ensure-source
    @echo "✅ geo_data_{iso,chn,usa}.bin generated"

[group: 'dev']
fetch-natural-earth:
    cargo run --manifest-path ../tools/geo_rasterizer/Cargo.toml --release --bin geo_rasterizer -- \
      --ensure-source --download-only
    @echo "✅ natural earth iso/chn/usa present in ../tools/geo_rasterizer/natural_earth/"

# Generate all required files for flutter build. Need to be reran every time rust api or journey kernel is updated
[group: 'dev']
pre-build:
    @echo "🛠️  Running pre-build"
    just rasterize-geo
    just journey-kernel-build
    just copy-webview-assets
    just frb-generate
    @echo "✅ Pre-build completed"


# Checking all code
[group: 'dev']
check:
    @echo "🛠️  Checking all code"
    just rust-check
    just journey-kernel-check
    just geo-data-format-check
    just geo-rasterizer-check
    just flutter-check
    @echo "✅ Checking completed"

# Geo tooling tests; CI runs these only when geo-related files change
[group: 'dev']
test-geo:
    @echo "🧪 Running geo tooling tests"
    just geo-data-format-test
    just geo-rasterizer-test
    @echo "✅ Geo tooling tests completed"

# App tests (flutter + journey kernel + rust core); regenerates geo bins first
[group: 'dev']
test-app:
    @echo "🧪 Running app tests"
    just rasterize-geo
    just flutter-test
    just journey-kernel-test
    just rust-test
    @echo "✅ App tests completed"

# Run all tests
[group: 'dev']
test:
    @echo "🛠️  Running all tests"
    just test-geo
    just test-app
    @echo "✅ Test completed"

# Formatting all code
[group: 'dev']
format:
    @echo "🛠️  Running code format"
    just journey-kernel-fmt
    just rust-fmt
    just geo-data-format-fmt
    just geo-rasterizer-fmt
    just flutter-fmt
    @echo "✅ Format completed"

# Regenerate the rasterizer's checked-in golden fixture (only after a deliberate algorithm change)
[group: 'dev']
regenerate-golden:
    @echo "🛠️  Regenerating geo_rasterizer golden fixture"
    cargo run --manifest-path ../tools/geo_rasterizer/Cargo.toml --bin geo_rasterizer -- \
      --pov iso \
      --countries ../tools/geo_rasterizer/tests/fixtures/synthetic.geojson \
      --registry ../tools/geo_rasterizer/tests/fixtures/synthetic_registry.toml \
      --output ../tools/geo_rasterizer/tests/fixtures/synthetic.bin
    @echo "✅ Golden fixture regenerated"

# Release build
[group: 'dev']
release-build:
    @echo "🛠️  Building release version"

    # Check if git workspace is clean
    @(git diff --quiet && git diff --cached --quiet) || (echo "Error: Uncommitted changes exist!"; exit 1)

    just pre-build
    @flutter build apk --release
    @flutter build ipa --release
    @echo "✅ Build completed"
